diff --git a/test/contract-eval-live-preflight.js b/test/contract-eval-live-preflight.js
new file mode 100644
index 0000000..20b0019
--- /dev/null
+++ b/test/contract-eval-live-preflight.js
@@ -0,0 +1,94 @@
+/**
+ * FL-40 authoritative-live preflight contract.
+ *
+ * Proves that a live-labelled evaluation cannot begin unless the requested
+ * real backend is mechanically enabled and credentialed; certification cannot
+ * use --limit/--cases; the manifest checksum is enforced; and the staging
+ * workflow explicitly maps protected backend configuration.
+ */
+import { readFileSync, writeFileSync, mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join, dirname } from "node:path";
+import { fileURLToPath } from "node:url";
+import { spawnSync } from "node:child_process";
+
+const HERE = dirname(fileURLToPath(import.meta.url));
+const ROOT = join(HERE, "..");
+const CLI = join(ROOT, "scripts", "eval-run.mjs");
+const MANIFEST = join(ROOT, "verification", "data", "eval-manifests", "authoritative-v1.json");
+const SIGNOFF = "signoff:eval-rubric:v1.0:KL:2026-07-21";
+
+function cleanEnv(extra = {}) {
+  const env = { ...process.env, ...extra };
+  for (const k of ["ANTHROPIC_API_KEY", "HEYDOC_LLM_KEY_REF", "HEYDOC_MEDGEMMA_KEY", "HEYDOC_MEDGEMMA_KEY_REF", "HEYDOC_MEDGEMMA_ENDPOINT"]) delete env[k];
+  return env;
+}
+
+function runCli(args, env = cleanEnv()) {
+  return spawnSync("node", [CLI, ...args], { cwd: ROOT, encoding: "utf8", env });
+}
+
+function run() {
+  const errors = [];
+  const dirs = [];
+  try {
+    // 1. Certification may not use directory order / --cases in place of a manifest.
+    const noManifest = runCli([
+      "--mode", "live", "--gate", "--cases", "SPEC-CARD-01-00023", "--backends", "claude", "--signoff-ref", SIGNOFF,
+    ]);
+    if (noManifest.status !== 1 || !/requires a certification manifest/i.test(noManifest.stderr + noManifest.stdout)) {
+      errors.push(`live gate without manifest was not refused correctly: ${noManifest.stderr}${noManifest.stdout}`);
+    }
+
+    // 2. Claude requested but not credentialed → refuse before generation.
+    const noClaude = runCli([
+      "--mode", "live", "--gate", "--manifest", MANIFEST, "--backends", "claude", "--signoff-ref", SIGNOFF,
+    ], cleanEnv({ HEYDOC_LLM_LIVE: "1" }));
+    if (noClaude.status !== 1 || !/backend claude is not mechanically live-enabled/i.test(noClaude.stderr + noClaude.stdout)) {
+      errors.push(`uncredentialed Claude was not refused: ${noClaude.stderr}${noClaude.stdout}`);
+    }
+
+    // 3. MedGemma requested without flag/endpoint/key → refuse before generation.
+    const noMedgemma = runCli([
+      "--mode", "live", "--gate", "--manifest", MANIFEST, "--backends", "medgemma", "--signoff-ref", SIGNOFF,
+    ]);
+    if (noMedgemma.status !== 1 || !/backend medgemma is not mechanically live-enabled/i.test(noMedgemma.stderr + noMedgemma.stdout)) {
+      errors.push(`uncredentialed MedGemma was not refused: ${noMedgemma.stderr}${noMedgemma.stdout}`);
+    }
+
+    // 4. Manifest checksum is a mechanical pin, not decorative metadata.
+    const d = mkdtempSync(join(tmpdir(), "eval-manifest-tamper-"));
+    dirs.push(d);
+    const bad = JSON.parse(readFileSync(MANIFEST, "utf8"));
+    bad.case_ids = bad.case_ids.slice(1);
+    const badPath = join(d, "bad.json");
+    writeFileSync(badPath, JSON.stringify(bad));
+    const tampered = runCli(["--mode", "replay", "--gate", "--manifest", badPath, "--backends", "claude"]);
+    if (tampered.status !== 1 || !/(case_count .* does not match|case_ids_sha256 mismatch)/i.test(tampered.stderr + tampered.stdout)) {
+      errors.push("tampered manifest checksum did not fail closed");
+    }
+
+    // 5. Workflow explicitly maps every protected value and uses the manifest.
+    const workflow = readFileSync(join(ROOT, ".github", "workflows", "staging-eval.yml"), "utf8");
+    for (const required of [
+      "ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}",
+      'HEYDOC_MEDGEMMA_LIVE: "1"',
+      "HEYDOC_MEDGEMMA_ENDPOINT: ${{ secrets.HEYDOC_MEDGEMMA_ENDPOINT }}",
+      "HEYDOC_MEDGEMMA_KEY: ${{ secrets.HEYDOC_MEDGEMMA_KEY }}",
+      "--manifest verification/data/eval-manifests/authoritative-v1.json",
+    ]) {
+      if (!workflow.includes(required)) errors.push(`workflow missing required live preflight wiring: ${required}`);
+    }
+    if (/--limit/.test(workflow)) errors.push("authoritative workflow still permits lexicographic --limit selection");
+  } finally {
+    dirs.forEach((d) => rmSync(d, { recursive: true, force: true }));
+  }
+
+  if (errors.length) {
+    console.error("Contract failures:", errors);
+    process.exit(1);
+  }
+  console.log("contract-eval-live-preflight: OK");
+}
+
+run();
