node_modules/
*.log
.DS_Store

# Environment / runtime data — never commit (CLAUDE.md <security_and_secrets>, <data_handling>)
.env
.env.*
.heydoc-data/

# Secrets, mTLS certs and keys — injected at deploy time, never committed
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
certs/

# Per-developer local agent settings
.claude/settings.local.json

# Derived single-file repo digest (regenerate: node scripts/export-repo-digest.mjs)
breath-ezy-repo-digest*.md

# Derived latest-run verification artifacts — regenerated by `npm run verification`
# and each trunk run (overwritten every time). NOT the medicolegal record: the
# durable, append-only audit trail is the hash-chained ledger in .heydoc-data/.
verification/report.json
verification/evidence_tree.md
