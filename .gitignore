node_modules/
*.log
.DS_Store

# Environment / runtime data — never commit (CLAUDE.md <security_and_secrets>, <data_handling>)
.env
.env.*
.heydoc-data/

# Secrets, mTLS certs and keys — injected at deploy time, never committed
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
certs/

# Per-developer local agent settings
.claude/settings.local.json

# Local business/strategy source material (binary docs, potentially sensitive) —
# staged by the operator for reference, never version-controlled here.
Projects/

# macOS / cloud-sync duplicate copies ("foo 2.json", "bar 3.js"). These are
# conflict/duplication artifacts of a real tracked file — never real work. Guard
# so an ingest or bulk `git add` can't sweep them back in (they were committed
# once by accident under data/cases/ and removed).
* [0-9].*

# Derived single-file repo digest (regenerate: node scripts/export-repo-digest.mjs)
breath-ezy-repo-digest*.md

# Case-factory transport artifacts (FLOW_PLAN H4). A `.casebundle.json` / `.caseseed.json`
# is an authoring/transport artifact only — it is split by `cases:ingest` BEFORE anything
# reaches the pipeline (transformation-protocol §7.9). Never let one land under data/cases/.
*.casebundle.json
*.caseseed.json
# Generator scratch output (fixtures → bundles) — regenerate with generate-from-fixture.js
case-factory/out/

# Derived latest-run verification artifacts — regenerated by `npm run verification`
# and each trunk run (overwritten every time). NOT the medicolegal record: the
# durable, append-only audit trail is the hash-chained ledger in .heydoc-data/.
verification/report.json
verification/evidence_tree.md

# Licensed terminology material — MUST NEVER be committed (CLAUDE.md
# <security_and_secrets>: NCTS licence material must not enter the repo). SNOMED
# CT-AU / NCTS RF2 distributions are governed by the SNOMED CT affiliate licence
# + NCTS terms; they are loaded into infrastructure at deploy, never version-
# controlled. Belt-and-braces so an 800MB+ licensed release can never be added
# by accident.
NCTS_*
*_RF2_*
**/SnomedCT*RF2*/
*.rf2
# Large distribution archives (terminology releases, vendor bundles) — deploy-injected.
*.zip

# Case-transform workflow scaffolding (session-local; references scratchpad paths)
.pilot-review/
